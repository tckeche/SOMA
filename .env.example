
# Role provisioning at signup (determineRole in server/routes.ts).
# Any NEW account whose email is on TUTOR_EMAIL_DOMAIN is provisioned as a
# tutor automatically (regardless of the portal used). This is the unconditional
# domain check — it does not depend on the client-supplied requested_role.
TUTOR_EMAIL_DOMAIN=melaniacalvin.com
# Optional comma-separated allowlist of individual emails (on OTHER domains)
# that may be provisioned as tutors at signup. Leave blank for domain-only.
TUTOR_EMAIL_ALLOWLIST=
# The single super-admin account.
SUPER_ADMIN_EMAIL=tckeche@gmail.com

# PDF dual AI marking (disabled by default; no secrets here)
PDF_DUAL_MARKING_ENABLED=false
PDF_MARKER_A_PROVIDER=
PDF_MARKER_A_MODEL=
PDF_MARKER_B_PROVIDER=
PDF_MARKER_B_MODEL=
PDF_MARKING_ALLOW_SAME_PROVIDER=false
PDF_MARKING_REQUIRE_TUTOR_APPROVAL=true
PDF_MARKING_WORKER_ENABLED=false
PDF_MARKING_MAX_PAGES=50
PDF_MARKING_MAX_ATTEMPTS=3
PDF_MARKING_PROVIDER_TIMEOUT_MS=120000
PDF_MARKING_POLL_MS=5000
